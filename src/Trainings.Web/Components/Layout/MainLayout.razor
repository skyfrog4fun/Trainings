@inherits LayoutComponentBase

<nav class="navbar sticky-top navbar-dark bg-dark shadow-sm">
    <div class="container-fluid">
        <a class="navbar-brand fw-bold" href="/">🏋️ Trainings</a>
        <div class="dropdown">
            <button class="btn btn-outline-light" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="Menu">
                ☰
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow">
                <li>
                    <NavLink class="dropdown-item" href="" Match="NavLinkMatch.All">🏠 Dashboard</NavLink>
                </li>
                <li>
                    <NavLink class="dropdown-item" href="trainings">📅 Trainings</NavLink>
                </li>
                <AuthorizeView Roles="Participant">
                    <li>
                        <NavLink class="dropdown-item" href="my-registrations">📋 My Registrations</NavLink>
                    </li>
                </AuthorizeView>
                <AuthorizeView Roles="Trainer">
                    <li>
                        <NavLink class="dropdown-item" href="trainer-trainings">🎯 My Trainings</NavLink>
                    </li>
                </AuthorizeView>
                <AuthorizeView Roles="Admin,SuperAdmin">
                    <li>
                        <NavLink class="dropdown-item" href="users">👥 Users</NavLink>
                    </li>
                </AuthorizeView>
                <AuthorizeView Roles="SuperAdmin">
                    <li>
                        <NavLink class="dropdown-item" href="groups">🏢 Groups</NavLink>
                    </li>
                </AuthorizeView>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <a class="dropdown-item text-danger" href="/logout">🚪 Logout</a>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <span class="dropdown-item-text text-muted small">v@_version</span>
                </li>
            </ul>
        </div>
    </div>
</nav>

<main>
    <article class="content container-fluid px-2 px-md-4 py-3">
        <ErrorBoundary @ref="_errorBoundary">
            <ChildContent>
                @Body
            </ChildContent>
            <ErrorContent Context="ex">
                <div class="container px-2 px-md-4 py-5">
                    <div class="alert alert-danger shadow-sm" role="alert">
                        <h4 class="alert-heading">⚠️ Something went wrong</h4>
                        <p>An unexpected error occurred while loading this page. Please try again.</p>
                        <hr />
                        <div class="d-flex gap-2">
                            <button class="btn btn-outline-danger btn-sm" @onclick="ResetError">🔄 Try Again</button>
                            <a href="/" class="btn btn-outline-secondary btn-sm">🏠 Go to Dashboard</a>
                        </div>
                    </div>
                </div>
            </ErrorContent>
        </ErrorBoundary>
    </article>
</main>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private ErrorBoundary? _errorBoundary;

    private string _version = System.Reflection.Assembly
        .GetExecutingAssembly().GetName().Version?.ToString(3) ?? "1.0.0";

    private void ResetError() => _errorBoundary?.Recover();
}
