@page "/users"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "GroupAdmin")]
@inject IUserService UserService
@inject IUserRegistrationService UserRegistrationService
@inject IPasswordResetService PasswordResetService
@inject IEmailService EmailService
@inject NavigationManager NavigationManager
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>User Management</PageTitle>

<div class="container px-2 px-md-4">
    <div class="d-flex justify-content-between align-items-center my-3">
        <h2>Users</h2>
        <button class="btn btn-success" @onclick="ShowCreateForm">+ New User</button>
    </div>

    <AuthorizeView Policy="SuperAdmin">
        <div class="card mb-4 border-info">
            <div class="card-header bg-info text-white fw-bold">🔧 SMTP Configuration Test</div>
            <div class="card-body">
                <p class="mb-2 text-muted">Send a test email to your account to verify that the SMTP configuration is working correctly.</p>
                <button class="btn btn-info" @onclick="SendTestEmail" disabled="@_testEmailSending">
                    @if (_testEmailSending)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                    }
                    📧 Send Test Email to Me
                </button>
                @if (_testEmailResult != null)
                {
                    <div class="alert @(_testEmailSuccess ? "alert-success" : "alert-danger") mt-2 mb-0">@_testEmailResult</div>
                }
            </div>
        </div>
    </AuthorizeView>

    @if (_showForm)
    {
        <div class="card mb-4">
            <div class="card-body">
                <h5>@(_editUserId == 0 ? "Create User" : "Edit User")</h5>
                <div class="row g-2">
                    <div class="col-12 col-md-6">
                        <label class="form-label">First Name *</label>
                        <input class="form-control" placeholder="First Name" @bind="_formFirstName" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Last Name *</label>
                        <input class="form-control" placeholder="Last Name" @bind="_formLastName" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Email *</label>
                        <input class="form-control" type="email" placeholder="Email" @bind="_formEmail" />
                    </div>
                    @if (_editUserId == 0)
                    {
                        <div class="col-12 col-md-6">
                            <label class="form-label">Password *</label>
                            <input class="form-control" type="password" placeholder="Password" @bind="_formPassword" />
                        </div>
                    }
                    <div class="col-12 col-md-4">
                        <label class="form-label">Role</label>
                        <select class="form-select" @bind="_formRole">
                            <option value="User">User</option>
                            <option value="SuperAdmin">Super Admin</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Gender</label>
                        <select class="form-select" @bind="_formGender">
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                            <option value="Other">Other</option>
                        </select>
                    </div>
                    <div class="col-12 col-md-4">
                        <label class="form-label">Birthday</label>
                        <input class="form-control" type="date" @bind="_formBirthday" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Mobile</label>
                        <input class="form-control" placeholder="+1 555 000 0000" @bind="_formMobile" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">City</label>
                        <input class="form-control" placeholder="City" @bind="_formCity" />
                    </div>
                    @if (_editUserId != 0)
                    {
                        <div class="col-12 col-md-6">
                            <label class="form-label">Entry Date</label>
                            <input class="form-control" type="date" @bind="_formEntryDate" />
                        </div>
                        <div class="col-12">
                            <label class="form-label">Welcome Message / Bio</label>
                            <textarea class="form-control" rows="2" @bind="_formWelcomeMessage" placeholder="Bio or welcome message..."></textarea>
                        </div>
                    }
                </div>
                <div class="mt-3">
                    <button class="btn btn-primary me-2" @onclick="SaveUser">Save</button>
                    <button class="btn btn-secondary" @onclick="CancelForm">Cancel</button>
                </div>
                @if (_formError != null) { <div class="alert alert-danger mt-2">@_formError</div> }
            </div>
        </div>
    }

    @if (_loading)
    {
        <div class="text-center"><div class="spinner-border" role="status"></div></div>
    }
    else
    {
        @if (_pendingUsers.Any())
        {
            <div class="card mb-4 border-warning">
                <div class="card-header bg-warning text-dark fw-bold">
                    ⏳ Pending Approvals (@_pendingUsers.Count)
                </div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr><th>Name</th><th>Email</th><th>Registered</th><th>Actions</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var user in _pendingUsers)
                            {
                                <tr>
                                    <td>@user.DisplayName</td>
                                    <td>@user.Email</td>
                                    <td>@user.CreationDate.ToString("MMM d, yyyy")</td>
                                    <td>
                                        <button class="btn btn-sm btn-success me-1" @onclick="() => ApproveUser(user)">Approve</button>
                                        <button class="btn btn-sm btn-danger" @onclick="() => RejectUser(user)">Reject</button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <div class="table-responsive">
            <table class="table table-striped">
                <thead>
                    <tr><th>Name</th><th>Email</th><th>Role</th><th>Email Verified</th><th>Active</th><th>Actions</th></tr>
                </thead>
                <tbody>
                    @foreach (var user in _users)
                    {
                        <tr>
                            <td>@user.DisplayName</td>
                            <td>@user.Email</td>
                            <td><span class="badge @RoleBadge(user.Role)">@user.Role</span></td>
                            <td>
                                @if (user.EmailConfirmedAt.HasValue)
                                {
                                    <span class="text-success" title="Confirmed @user.EmailConfirmedAt.Value.ToString("MMM d, yyyy")">✓</span>
                                }
                                else
                                {
                                    <span class="text-muted">✗</span>
                                }
                            </td>
                            <td>@(user.IsActive ? "✓" : "✗")</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary me-1" @onclick="() => EditUser(user)">Edit</button>
                                <button class="btn btn-sm btn-outline-secondary me-1" title="Send email verification" @onclick="() => SendEmailVerification(user)" disabled="@(user.EmailConfirmedAt.HasValue)">📧 Verify</button>
                                <button class="btn btn-sm btn-outline-secondary me-1" title="Send welcome & password reset" @onclick="() => SendWelcome(user)">🔑 Welcome</button>
                                <button class="btn btn-sm btn-outline-danger" @onclick="() => ToggleActive(user)">
                                    @(user.IsActive ? "Deactivate" : "Activate")
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @if (_actionResult != null)
        {
            <div class="alert @(_actionSuccess ? "alert-success" : "alert-danger") mt-2">@_actionResult</div>
        }
    }
</div>

@code {
    private List<UserDto> _users = new();
    private List<UserDto> _pendingUsers = new();
    private bool _loading = true;
    private bool _showForm = false;
    private int _editUserId = 0;
    private string _formFirstName = "", _formLastName = "", _formEmail = "", _formPassword = "";
    private string _formRole = "User", _formGender = "Other";
    private DateTime? _formBirthday;
    private string _formMobile = "", _formCity = "", _formWelcomeMessage = "";
    private DateTime? _formEntryDate;
    private string? _formError;

    private bool _testEmailSending = false;
    private bool _testEmailSuccess = false;
    private string? _testEmailResult;

    private bool _actionSuccess = false;
    private string? _actionResult;

    protected override async Task OnInitializedAsync()
    {
        await LoadUsers();
    }

    private async Task LoadUsers()
    {
        _loading = true;
        _users = (await UserService.GetAllAsync()).ToList();
        _pendingUsers = (await UserRegistrationService.GetPendingApprovalsAsync()).ToList();
        _loading = false;
    }

    private void ShowCreateForm()
    {
        _editUserId = 0;
        _formFirstName = _formLastName = _formEmail = _formPassword = "";
        _formRole = "User";
        _formGender = "Other";
        _formBirthday = null;
        _formMobile = _formCity = _formWelcomeMessage = "";
        _formEntryDate = null;
        _formError = null;
        _showForm = true;
    }

    private void EditUser(UserDto user)
    {
        _editUserId = user.Id;
        _formFirstName = user.FirstName;
        _formLastName = user.LastName;
        _formEmail = user.Email;
        _formRole = user.Role.ToString();
        _formGender = user.Gender.ToString();
        _formBirthday = user.Birthday.HasValue ? user.Birthday.Value.ToDateTime(TimeOnly.MinValue) : null;
        _formMobile = user.Mobile ?? "";
        _formCity = user.City ?? "";
        _formWelcomeMessage = user.WelcomeMessage ?? "";
        _formEntryDate = user.EntryDate;
        _formError = null;
        _showForm = true;
    }

    private async Task SaveUser()
    {
        _formError = null;
        try
        {
            var birthday = _formBirthday.HasValue ? DateOnly.FromDateTime(_formBirthday.Value) : (DateOnly?)null;

            if (_editUserId == 0)
            {
                await UserService.CreateAsync(new CreateUserDto
                {
                    FirstName = _formFirstName,
                    LastName = _formLastName,
                    Email = _formEmail,
                    Password = _formPassword,
                    Role = Enum.Parse<UserRole>(_formRole),
                    Gender = Enum.Parse<Gender>(_formGender),
                    Birthday = birthday,
                    Mobile = string.IsNullOrWhiteSpace(_formMobile) ? null : _formMobile,
                    City = string.IsNullOrWhiteSpace(_formCity) ? null : _formCity
                });
            }
            else
            {
                var user = _users.First(u => u.Id == _editUserId);
                await UserService.UpdateAsync(new UpdateUserDto
                {
                    Id = _editUserId,
                    FirstName = _formFirstName,
                    LastName = _formLastName,
                    Email = _formEmail,
                    Role = Enum.Parse<UserRole>(_formRole),
                    Gender = Enum.Parse<Gender>(_formGender),
                    IsActive = user.IsActive,
                    Birthday = birthday,
                    Mobile = string.IsNullOrWhiteSpace(_formMobile) ? null : _formMobile,
                    City = string.IsNullOrWhiteSpace(_formCity) ? null : _formCity,
                    EntryDate = _formEntryDate,
                    WelcomeMessage = string.IsNullOrWhiteSpace(_formWelcomeMessage) ? null : _formWelcomeMessage
                });
            }
            _showForm = false;
            await LoadUsers();
        }
        catch (Exception ex)
        {
            _formError = ex.Message;
        }
    }

    private async Task ToggleActive(UserDto user)
    {
        await UserService.UpdateAsync(new UpdateUserDto
        {
            Id = user.Id,
            FirstName = user.FirstName,
            LastName = user.LastName,
            Email = user.Email,
            Role = user.Role,
            Gender = user.Gender,
            IsActive = !user.IsActive,
            Birthday = user.Birthday,
            Mobile = user.Mobile,
            City = user.City,
            EntryDate = user.EntryDate,
            WelcomeMessage = user.WelcomeMessage
        });
        await LoadUsers();
    }

    private async Task ApproveUser(UserDto user)
    {
        await UserRegistrationService.ApproveUserAsync(user.Id, 0);
        await LoadUsers();
    }

    private async Task RejectUser(UserDto user)
    {
        await UserRegistrationService.RejectUserAsync(user.Id, 0);
        await LoadUsers();
    }

    private void CancelForm() => _showForm = false;

    private async Task SendEmailVerification(UserDto user)
    {
        _actionResult = null;
        try
        {
            await UserRegistrationService.ResendEmailConfirmationAsync(user.Id);
            _actionSuccess = true;
            _actionResult = $"Email verification sent to {user.Email}.";
        }
        catch (Exception ex)
        {
            _actionSuccess = false;
            _actionResult = $"Failed: {ex.Message}";
        }
    }

    private async Task SendWelcome(UserDto user)
    {
        _actionResult = null;
        try
        {
            await PasswordResetService.SendWelcomeAsync(user.Email);
            _actionSuccess = true;
            _actionResult = $"Welcome & password reset email sent to {user.Email}.";
        }
        catch (Exception ex)
        {
            _actionSuccess = false;
            _actionResult = $"Failed: {ex.Message}";
        }
    }

    private async Task SendTestEmail()
    {
        _testEmailSending = true;
        _testEmailResult = null;
        try
        {
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var email = authState.User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
            if (string.IsNullOrWhiteSpace(email))
            {
                _testEmailSuccess = false;
                _testEmailResult = "Could not determine your email address from the current session.";
                return;
            }
            await EmailService.SendTestEmailAsync(email);
            _testEmailSuccess = true;
            _testEmailResult = $"Test email sent successfully to {email}.";
        }
        catch (Exception ex)
        {
            _testEmailSuccess = false;
            _testEmailResult = $"Failed to send test email: {ex.Message}";
        }
        finally
        {
            _testEmailSending = false;
        }
    }

    private string RoleBadge(UserRole role) => role switch
    {
        UserRole.SuperAdmin => "bg-dark",
        _ => "bg-secondary"
    };
}
