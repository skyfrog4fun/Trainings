@page "/confirm-email"
@rendermode InteractiveServer
@inject IUserRegistrationService UserRegistrationService
@inject NavigationManager NavigationManager

<PageTitle>Confirm Email</PageTitle>

<div class="container">
    <div class="row justify-content-center mt-5">
        <div class="col-12 col-sm-8 col-md-6 col-lg-4">
            <div class="card shadow">
                <div class="card-body p-4 text-center">
                    @if (_loading)
                    {
                        <div class="spinner-border text-primary mb-3" role="status"></div>
                        <p>Confirming your email...</p>
                    }
                    else if (_success)
                    {
                        <div class="text-success mb-3" style="font-size:3rem;">✓</div>
                        <h5>Email Confirmed!</h5>
                        <p class="text-muted">Your email has been confirmed. Your account is pending admin approval.</p>
                        <a href="/login" class="btn btn-primary w-100">Back to Login</a>
                    }
                    else
                    {
                        <div class="text-danger mb-3" style="font-size:3rem;">✗</div>
                        <h5>Confirmation Failed</h5>
                        <p class="text-muted">@_error</p>
                        <a href="/login" class="btn btn-outline-primary w-100">Back to Login</a>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private bool _loading = true, _success;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);
        var token = query.TryGetValue("token", out var t) ? t.ToString() : "";

        if (string.IsNullOrEmpty(token))
        {
            _error = "Invalid or missing confirmation token.";
            _loading = false;
            return;
        }

        try
        {
            await UserRegistrationService.ConfirmEmailAsync(token);
            _success = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
