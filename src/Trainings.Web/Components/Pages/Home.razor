@page "/"
@rendermode InteractiveServer
@attribute [Authorize]
@using Trainings.Web.Auth
@inject AuthenticationStateProvider AuthStateProvider
@inject ITrainingService TrainingService
@inject IRegistrationService RegistrationService
@inject INotificationLogService NotificationLogService
@inject IGroupService GroupService

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid px-2 px-md-4">
    <h2 class="my-3">Welcome, @_userName!</h2>

    @if (_isSuperAdmin)
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card text-bg-primary">
                    <div class="card-body text-center">
                        <h3>@_totalTrainings</h3>
                        <p class="mb-0">Total Trainings</p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card text-bg-success">
                    <div class="card-body text-center">
                        <h3>@_successCount30d</h3>
                        <p class="mb-0">Emails Sent (30d)</p>
                    </div>
                </div>
            </div>
            <div class="col-6 col-md-3">
                <div class="card text-bg-danger">
                    <div class="card-body text-center">
                        <h3>@_failureCount30d</h3>
                        <p class="mb-0">Email Failures (30d)</p>
                    </div>
                </div>
            </div>
        </div>

        @if (_recentAttempts.Any())
        {
            <div class="card mb-4">
                <div class="card-header fw-bold">📊 Recent Notification Activity</div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr><th>Date (UTC)</th><th>Action</th><th>Recipient</th><th>Status</th><th>Error</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var attempt in _recentAttempts)
                            {
                                var last = attempt.Last();
                                var count = attempt.Count;
                                <tr>
                                    <td class="small">@last.CreatedAt.ToString("MMM d, HH:mm") UTC</td>
                                    <td class="small">@last.Action</td>
                                    <td class="small text-muted">@last.RecipientEmail</td>
                                    <td>
                                        @if (last.IsSuccess)
                                        {
                                            <span class="badge bg-success" title="@count config(s) tried">✓ @count</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger" title="@count config(s) tried, all failed">✗ @count</span>
                                        }
                                    </td>
                                    <td class="small text-danger">@last.ErrorMessage</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }

        <p><a href="/users" class="btn btn-primary me-2">Manage Users</a><a href="/config/mail" class="btn btn-outline-secondary">Mail Config</a></p>
    }
    else if (_isGroupAdmin)
    {
        <div class="row g-3 mb-4">
            <div class="col-6 col-md-3">
                <div class="card text-bg-primary">
                    <div class="card-body text-center">
                        <h3>@_totalTrainings</h3>
                        <p class="mb-0">Total Trainings</p>
                    </div>
                </div>
            </div>
        </div>
        <p>
            <a href="/users" class="btn btn-primary me-2">Manage Users</a>
            @if (_adminGroupSlug != null)
            {
                <a href="/groups/@_adminGroupSlug/members" class="btn btn-outline-primary">Manage Group</a>
            }
        </p>
    }
    else if (!_isGroupMember && !_isGroupTrainer)
    {
        @* Plain user with no group roles — show their membership status *@
        @if (_userMemberships.Any())
        {
            <div class="card mb-4">
                <div class="card-header fw-bold">📋 Your Group Memberships</div>
                <div class="table-responsive">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr><th>Group</th><th>Role</th><th>Status</th><th>Requested</th></tr>
                        </thead>
                        <tbody>
                            @foreach (var m in _userMemberships)
                            {
                                <tr>
                                    <td>@m.GroupName</td>
                                    <td><span class="badge bg-secondary">@m.Role</span></td>
                                    <td>
                                        @switch (m.Status)
                                        {
                                            case Trainings.Domain.Enums.GroupMembershipStatus.Approved:
                                                <span class="badge bg-success">Approved</span>
                                                break;
                                            case Trainings.Domain.Enums.GroupMembershipStatus.Pending:
                                                <span class="badge bg-warning text-dark">Pending</span>
                                                break;
                                            case Trainings.Domain.Enums.GroupMembershipStatus.Declined:
                                                <span class="badge bg-danger">Declined</span>
                                                break;
                                        }
                                    </td>
                                    <td class="small text-muted">@m.RequestedAt.ToString("MMM d, yyyy")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                You are not a member of any group yet. <a href="/trainings">Browse trainings</a> or wait for an administrator to add you to a group.
            </div>
        }
    }

    @if (_isGroupTrainer)
    {
        <h4>Your Upcoming Trainings</h4>
        <TrainingList Trainings="_trainerTrainings" ShowActions="true" />
        <a href="/trainer-trainings" class="btn btn-primary mt-2">Manage All Trainings</a>
    }

    @if (_isGroupMember)
    {
        <h4>Upcoming Trainings</h4>
        <TrainingList Trainings="_upcomingTrainings" ShowRegisterButton="true" CurrentUserId="_userId" />
        <a href="/trainings" class="btn btn-outline-primary mt-2">View All Trainings</a>
    }
</div>

@code {
    private string _userName = "";
    private int _userId;
    private bool _isSuperAdmin, _isGroupAdmin, _isGroupTrainer, _isGroupMember;
    private int _totalTrainings;
    private int _successCount30d, _failureCount30d;
    private List<TrainingDto> _trainerTrainings = new();
    private List<TrainingDto> _upcomingTrainings = new();
    private IReadOnlyList<Trainings.Domain.Entities.NotificationLog> _recentLogs = Array.Empty<Trainings.Domain.Entities.NotificationLog>();
    private List<List<Trainings.Domain.Entities.NotificationLog>> _recentAttempts = new();
    private List<UserMembershipViewModel> _userMemberships = new();
    private string? _adminGroupSlug;

    private record UserMembershipViewModel(
        string GroupName,
        Trainings.Domain.Enums.GroupMemberRole Role,
        Trainings.Domain.Enums.GroupMembershipStatus Status,
        DateTime RequestedAt);

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        _userName = user.FindFirst(System.Security.Claims.ClaimTypes.Name)?.Value ?? "User";
        _userId = int.TryParse(user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out var id) ? id : 0;

        _isSuperAdmin = user.HasClaim(AppClaimTypes.SuperAdmin, "true");
        _isGroupAdmin = _isSuperAdmin || user.Claims.Any(c => c.Type.StartsWith(AppClaimTypes.GroupRolePrefix, StringComparison.Ordinal) && c.Value == "Admin");
        _isGroupTrainer = _isGroupAdmin || user.Claims.Any(c => c.Type.StartsWith(AppClaimTypes.GroupRolePrefix, StringComparison.Ordinal) && c.Value == "Trainer");
        _isGroupMember = _isGroupTrainer || user.Claims.Any(c => c.Type.StartsWith(AppClaimTypes.GroupRolePrefix, StringComparison.Ordinal));

        if (_isSuperAdmin || _isGroupAdmin)
        {
            var all = await TrainingService.GetAllAsync();
            _totalTrainings = all.Count();
        }

        if (_isSuperAdmin)
        {
            var since30d = DateTime.UtcNow.AddDays(-30);
            _successCount30d = await NotificationLogService.GetSuccessCountAsync(since30d);
            _failureCount30d = await NotificationLogService.GetFailureCountAsync(since30d);
            _recentLogs = await NotificationLogService.GetRecentLogsAsync(50);

            // Group logs by AttemptId; take the 10 most recent distinct attempts
            _recentAttempts = _recentLogs
                .GroupBy(l => l.AttemptId)
                .Select(g => g.OrderBy(l => l.CreatedAt).ToList())
                .OrderByDescending(g => g.Last().CreatedAt)
                .Take(10)
                .ToList();
        }

        if (_isGroupAdmin && !_isSuperAdmin)
        {
            // Find first group the user admins so we can provide a direct link
            var adminGroupIdClaim = user.Claims
                .Where(c => c.Type.StartsWith(AppClaimTypes.GroupRolePrefix, StringComparison.Ordinal) && c.Value == "Admin")
                .Select(c => c.Type.Replace(AppClaimTypes.GroupRolePrefix, ""))
                .FirstOrDefault();
            if (int.TryParse(adminGroupIdClaim, out var adminGroupId))
            {
                var adminGroup = await GroupService.GetByIdAsync(adminGroupId);
                var slug = adminGroup?.Slug;
                _adminGroupSlug = string.IsNullOrEmpty(slug) ? null : slug;
            }
        }

        if (_isGroupTrainer)
        {
            _trainerTrainings = (await TrainingService.GetByTrainerIdAsync(_userId)).Take(5).ToList();
        }

        if (_isGroupMember)
        {
            _upcomingTrainings = (await TrainingService.GetActiveAsync())
                .Where(t => t.DateTime >= DateTime.Now)
                .Take(5)
                .ToList();
        }

        // For plain users (not admin/trainer), show their membership statuses
        if (!_isGroupAdmin && !_isGroupTrainer && _userId > 0)
        {
            var memberships = await GroupService.GetAllMembershipsForUserAsync(_userId);
            var groups = (await GroupService.GetAllAsync()).ToDictionary(g => g.Id, g => g.Name);
            _userMemberships = memberships
                .Select(m => new UserMembershipViewModel(
                    groups.TryGetValue(m.GroupId, out var groupName) ? groupName : "Unknown",
                    m.Role,
                    m.Status,
                    m.RequestedAt))
                .OrderBy(m => m.GroupName)
                .ToList();
        }
    }
}
