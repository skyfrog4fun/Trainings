# Environment variables for the Trainings application stack.
# Copy this file to .env and fill in the values.
# NEVER commit the .env file to source control.

# Initial admin user created by the database seeder on first run.
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ChangeMe!2025

# GitHub Container Registry repository (used in docker-compose.yml).
# Format: <github-username>/<repo-name>  (all lowercase)
GITHUB_REPOSITORY=skyfrog4fun/trainings

# SMTP / Email (e.g. Brevo, SendGrid)
# SMTP_USER and SMTP_PASSWORD are stored as GitHub Actions secrets.
# Copy the values manually into the .env file on the NAS — never commit real credentials.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-login@example.com
SMTP_PASSWORD=your-api-key-here
SMTP_FROM=noreply@yourdomain.com

# Public base URL of the application (used for links in emails).
# Set this to the publicly reachable URL, e.g. https://trainings.example.com
APP_BASE_URL=https://trainings.example.com

# Optional: Cloudflare Dynamic DNS updater
# Create a scoped API token in Cloudflare Dashboard > Profile > API Tokens
# with "Edit zone DNS" permissions for your zone only.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ZONE=example.com
# CLOUDFLARE_SUBDOMAIN=trainings
